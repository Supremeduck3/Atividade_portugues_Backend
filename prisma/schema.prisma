generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Usuario {
    id        Int      @id @default(autoincrement())
    nome      String
    ativo    Boolean  @default(true)
    data       DateTime @db.Date
    @@map("usuario")
}
model Livro {
  id                            Int      @id @default(autoincrement())
  titulo                        String
  titulo_en                     String
  capa                          String
  autor                         String
  anoPublicacao                 Int
  genero                        String
  genero_en                     String
  resumo                        String   @db.Text
  resumo_en                     String   @db.Text
  contexto                      String   @db.Text
  contexto_en                   String   @db.Text
  estiloEscrita                 String   @db.Text
  estiloEscrita_en              String   @db.Text
  enredo                        String   @db.Text
  enredo_en                     String   @db.Text
  verossimilhanca               String   @db.Text
  verossimilhanca_en            String   @db.Text
  personagens                   String[]
  caracteristicasLiterarias     String   @db.Text
  caracteristicasLiterarias_en  String   @db.Text
  conclusao                     String   @db.Text
  conclusao_en                  String   @db.Text
}
model Dica {
    id Int @id @default(autoincrement())
    conteudo String @db.Text
    conteudo_en String @db.Text
    interpretacao String
    interpretacao_en String
    temasVestibular String
    temasVestibular_en String
}

model TemasRedacao{
    id Int @id @default(autoincrement())
    assunto String
    assunto_en String
    dificuldade Int
}

model Quiz{
    id Int @id @default(autoincrement())
    conteudoQuestao String
    conteudoQuestao_en String
    respostaQuestao String
    respostaQuestao_en String
}

model Curiosidades{
    id Int @id @default(autoincrement())
    fatosLivro String
    fatosLivro_en String
    autor String
    autor_en String
    contexto String
    contexto_en String
}
