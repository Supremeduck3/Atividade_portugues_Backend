generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Livro {
  id                           Int      @id @default(autoincrement())
  titulo                       String
  titulo_en                    String
  capa                         String
  autor                        String
  anoPublicacao                Int
  genero                       String
  genero_en                    String
  resumo                       String
  resumo_en                    String
  contexto                     String
  contexto_en                  String
  estiloEscrita                String
  estiloEscrita_en             String
  enredo                       String
  enredo_en                    String
  verossimilhanca              String
  verossimilhanca_en           String
  personagens                  String[]
  caracteristicasLiterarias    String
  caracteristicasLiterarias_en String
  conclusao                    String
  conclusao_en                 String
}

model Dica {
  id                 Int    @id @default(autoincrement())
  conteudo           String
  conteudo_en        String
  interpretacao      String
  interpretacao_en   String
  temasVestibular    String
  temasVestibular_en String
}

model TemasRedacao {
  id          Int    @id @default(autoincrement())
  assunto     String
  assunto_en  String
  dificuldade Int
}

model Quiz {
  id                 Int    @id @default(autoincrement())
  conteudoQuestao    String
  conteudoQuestao_en String
  respostaQuestao    String
  respostaQuestao_en String
}

model Curiosidades {
  id            Int    @id @default(autoincrement())
  fatosLivro    String
  fatosLivro_en String
  autor         String
  autor_en      String
  contexto      String
  contexto_en   String
}

model usuario {
  id    Int      @id @default(autoincrement())
  nome  String
  ativo Boolean  @default(true)
  data  DateTime @default(now())
}
